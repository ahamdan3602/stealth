ENV=dev
DATABASE_URL=postgresql+psycopg://stealth:stealth@localhost:5432/stealth
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# OpenAI (embeddings)
OPENAI_API_KEY=sk-...

# Pinecone (vector store) — create a serverless index named stealth-medical
PINECONE_API_KEY=pc-...
PINECONE_INDEX=stealth-medical

# RAG chain LLM (gpt-4o recommended for clinical accuracy)
CHAT_MODEL=gpt-4o

# LangSmith tracing (optional — omit to disable)
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=medguard-ai

# Guardrails (milestone 4)
GUARDRAIL_GROUNDEDNESS_THRESHOLD=0.7   # 0-1; below this triggers self-correction
GUARDRAIL_MODEL=gpt-4o-mini            # model used for groundedness scoring
